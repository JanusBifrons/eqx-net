{
  "name": "eqx-peri",
  "private": true,
  "version": "0.0.0",
  "description": "EQX Peri — multiplayer space game. See docs/blueprint.md and .claude/plans/ for architecture.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "typecheck": "tsc -b tsconfig.core.json tsconfig.server.json tsconfig.client.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "coverage": "vitest run --coverage --exclude \"**/*.integration.test.ts\"",
    "bench": "vitest bench --run",
    "e2e": "playwright test --project=smoke --project=feature",
    "e2e:smoke": "playwright test --project=smoke",
    "e2e:gate": "playwright test --project=gate",
    "e2e:headed": "cross-env PWHEADED=1 playwright test --project=smoke --project=feature",
    "e2e:scenarios": "playwright test --project=smoke tests/e2e/scenarios/",
    "e2e:netgate": "tsx tests/netgate/run-netgate.ts",
    "e2e:diag": "playwright test --config=playwright.diag.config.ts",
    "build:client": "vite build",
    "build:server": "tsc -b tsconfig.server.json",
    "build": "pnpm run build:server && pnpm run build:client",
    "dev:server": "cross-env NODE_OPTIONS=--max-semi-space-size=128 tsx watch --tsconfig tsconfig.server.json src/server/index.ts",
    "dev:server:nowatch": "cross-env NODE_OPTIONS=--max-semi-space-size=128 tsx --tsconfig tsconfig.server.json src/server/index.ts",
    "dev:server:gctrace": "cross-env NODE_OPTIONS=\"--max-semi-space-size=128 --trace-gc-verbose\" tsx --tsconfig tsconfig.server.json src/server/index.ts",
    "dev:client": "vite",
    "format": "prettier --write .",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "@dimforge/rapier2d-compat": "^0.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.1.10",
    "bcryptjs": "^3.0.3",
    "colyseus": "^0.16.0",
    "colyseus.js": "^0.16.0",
    "dotenv": "^17.4.2",
    "eventemitter3": "^5.0.1",
    "express": "^4.21.2",
    "howler": "^2.2.4",
    "jose": "^6.2.3",
    "nipplejs": "^1.0.1",
    "pino": "^9.5.0",
    "pixi-filters": "^6.1.5",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@colyseus/testing": "^0.16.3",
    "@colyseus/tools": "^0.16.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
