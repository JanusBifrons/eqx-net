# EQX Peri — environment configuration example.
# Copy to .env for local dev. Vars marked (production-required) MUST be set
# in production or the server fails closed at boot.

# --- Runtime ---
# NODE_ENV=production switches CORS to closed-by-default, enables HSTS, gates
# the dev/test rooms + /dev routes off, and arms the fail-closed JWT check.
NODE_ENV=development
PORT=2567
# SQLite path. Production points this at a persistent volume (see
# docs/ops/deployment.md). Defaults to ./eqx.db in the cwd when unset.
DB_PATH=./eqx.db

# --- Ops kill-switches (NEVER set the EQX_* dev flags in production) ---
# Re-register the test/engineering rooms in a production-mode build for a
# controlled load test (S6). Leave unset in real production.
# EQX_ENABLE_TEST_ROOMS=1
# E2E-only: bypass testMode JoinOption gating. The server warns at boot if set
# in production.
# EQX_ALLOW_DEV_OVERRIDES=1
# Disable the Living World hunter-bot AI (peaceful build/playtest).
# EQX_DISABLE_LIVING_WORLD=1
# Cap on the /dev/events ring read size (matches ServerEventLog sizing).
# EQX_DEV_EVENTS_MAX=500

# --- Security ---
# (production-required) HMAC secret for session JWTs. In production a missing or
# placeholder value throws at boot (S9). Generate with: openssl rand -hex 32
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_TTL_DAYS=30
# Comma-separated browser origins allowed to read cross-origin responses (S1).
# When unset: non-production reflects ANY origin (dev/LAN ergonomics); production
# is closed (no cross-origin browser access). Set explicitly to lock production.
# ALLOWED_ORIGINS=https://play.example.com

# --- Google OAuth ---
GOOGLE_API_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_API_CLIENT_SECRET=your-google-client-secret
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
