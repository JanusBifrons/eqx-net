node_modules/
dist/
.pnpm-store/
.vite/
*.tsbuildinfo
.tsbuildinfo*

# database
eqx.db
eqx.db-wal
eqx.db-shm

# gameplay audit log — local rolling NDJSON history (per-machine, churning;
# NOT committed, unlike diag/). Queried via scripts/query-audit.mjs + /dev/audit.
audit-logs/

# test artefacts
playwright-report/
test-results/
coverage/
tests/e2e/.auth/

# editor/os
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# runtime data (SQLite lands here from Phase 7 onward)
data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# env
.env
.env.local
.env.*.local

# diag/ is COMMITTED — captures, perf baselines, and CDP traces persist
# in-repo as auditable artefacts. Phone smoke captures (POST /diag/capture),
# automated perf baselines, and one-off CDP profiles are reviewed alongside
# the commit that produced them; deleting one is a deliberate cleanup, not
# a default. *.log inside diag/ is still caught by the global *.log rule.
# Policy reversed 2026-05-24 (was: /diag/* with !/diag/perf-baseline/).
# See diag/README.md.

# session log scratch (e2e capture, debug, regression runs, etc) —
# written from inside the repo by Bash/PowerShell calls during dev
# sessions. Never belong in commits.
*.log
*.stackdump
# heap snapshots from `tests/e2e/heap-snapshot-diff.spec.ts` are 30-60 MB
# each (full JS-heap dump). Triage docs (P2-snapshot-diff*.md) extract
# the actionable ranking + are committed instead.
*.heapsnapshot

# Claude Code session-local state
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Netcode-health gate worktrees — created by tests/netgate/run-netgate.ts
# (incremental — preserved across runs to keep node_modules warm; never commit).
.claude/worktrees/
tests/mobile-perf/screenshots/
