node_modules/
dist/
.pnpm-store/
.vite/
*.tsbuildinfo
.tsbuildinfo*

# database
eqx.db
eqx.db-wal
eqx.db-shm

# test artefacts
playwright-report/
test-results/
coverage/
tests/e2e/.auth/

# editor/os
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# runtime data (SQLite lands here from Phase 7 onward)
data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# env
.env
.env.local
.env.*.local

# dev-only diagnostic captures (POST /diag/capture). Anchored to repo
# root with the leading slash so it does NOT shadow `tests/diag/` (the
# @diag E2E specs, e2e-rebuild Phase 2b).
# Use /diag/* (not /diag/) so subsequent negation rules can re-include
# specific subdirectories (perf-floor's perf-baseline/).
/diag/*
# perf-floor Phase 2 baselines — committed deliberately for diff-vs-future
# comparison and Phase 5 lock reads. Un-ignore the subdirectory only.
!/diag/perf-baseline/

# session log scratch (e2e capture, debug, regression runs, etc) —
# written from inside the repo by Bash/PowerShell calls during dev
# sessions. Never belong in commits.
*.log
*.stackdump

# Claude Code session-local state
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Netcode-health gate worktrees — created by tests/netgate/run-netgate.ts
# (incremental — preserved across runs to keep node_modules warm; never commit).
.claude/worktrees/
